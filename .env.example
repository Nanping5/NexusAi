
DEFAULT_SYSTEM_PROMPT="你是NexusAssistant，由Namping创造的AI助手。帮助用户解决一切问题，当用户问你是什么模型时，请如实告知你正在使用的模型名称。"

# RAG 配置
RAG_OPENAI_API_KEY=your_rag_openai_api_key_here

# MCP 服务配置
# 所有服务共享一个端口
MCP_SERVER_URL=http://localhost:8081/mcp

# 代理配置
HTTP_PROXY=

# SERP搜索API配置
SERPAPI_KEY=your_serpapi_key_here

# 阿里云翻译配置
ALIBABA_ACCESS_KEY_ID=your_alibaba_access_key_id_here
ALIBABA_ACCESS_KEY_SECRET=your_alibaba_access_key_secret_here

# 天气API
AMAP_API_KEY=your_amap_api_key_here

# Agent 模式配置
AGENT_MODE=react          # 启用 ReAct Agent 模式
AGENT_MAX_ITERATIONS=10   # 最大迭代次数
